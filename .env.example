# ==============================================================================
# GLOBAL & DATABASE (Root .env for docker-compose)
# ==============================================================================
ENVIRONMENT=local
LOG_LEVEL=INFO

# Ambyte SDK Configuration

# Authentication token (Generate via the Ambyte Dashboard -> Settings -> API Keys)
AMBYTE_API_KEY=sk_live_your_machine_key

# URL pointing to your deployed Ambyte Control Plane
AMBYTE_CONTROL_PLANE_URL=http://localhost:8000

# Operation Mode: REMOTE (call API), LOCAL (use compiled JSON), OFF (bypass)
AMBYTE_MODE=REMOTE

# Safety mechanism: If True, network errors will log a warning but ALLOW execution
AMBYTE_FAIL_OPEN=true

# Identifier for the application using this SDK (appears in Audit Logs)
AMBYTE_SERVICE_NAME=my-data-pipeline

# (LOCAL Mode Only) Path to the compiled `local_policies.json` artifact
AMBYTE_LOCAL_POLICY_PATH=./.ambyte/dist/local_policies.json

# Postgres Database (Used by docker-compose and Control Plane)
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ambyte

# Redis (Used for job queues, caching, and audit stream buffer)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # Leave blank for local docker-compose

# ==============================================================================
# CONTROL PLANE API (Management Server)
# ==============================================================================
# Generate a secure 32-byte hex key (e.g., `openssl rand -hex 32`)
SECRET_KEY=your_secure_random_string_here

# Allowed origins for CORS (Must include your frontend URL)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# First user bootstrapped by `src/scripts/init_db.py`
FIRST_SUPERUSER=admin@ambyte.ai
FIRST_SUPERUSER_PASSWORD=changethis

# Authentication (Clerk - get these from https://dashboard.clerk.com)
# Go to API Keys -> Advanced -> Issuer URL
CLERK_ISSUER=https://your-issuer.clerk.accounts.dev
# Go to Webhooks -> Add Endpoint -> Signing Secret
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret
# CLERK_AUDIENCE=  # Optional: specific audience if configured

# ==============================================================================
# AUDIT WORKER (Immutable Ledger)
# ==============================================================================
# 32-byte Hex-encoded Ed25519 Private Key used to digitally sign Audit Blocks.
# If left blank, it generates an ephemeral key (WARN: breaks hash chain on restart).
# Generate offline securely for production!
AMBYTE_AUDIT_SYSTEM_PRIVATE_KEY=

# Tuning parameters for the audit buffer (Optional overrides)
AMBYTE_AUDIT_BATCH_SIZE=1000
AMBYTE_AUDIT_BATCH_FLUSH_INTERVAL=1.0
AMBYTE_AUDIT_SEAL_MIN_LOGS=100
AMBYTE_AUDIT_SEAL_MAX_TIME_WINDOW=300

# ==============================================================================
# INGESTION PIPELINE (AI & Embeddings)
# ==============================================================================
# System API key for the ingest worker to write to the Control Plane
# NOTE: This is generated for you when you run `python src/scripts/init_db.py`
INGEST_WORKER_API_KEY=sk_ingest_your_generated_key

# OpenAI API Key used for extracting legal definitions and constraints (Pass 1 & 2)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Voyage AI Key used for domain-specific legal embeddings (voyage-law-2)
# Get from: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=pa-your-voyage-api-key

# AWS / MinIO Object Storage (Used by ingest worker for raw PDF uploads)
# Default values match the docker-compose MinIO service
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AMBYTE_INGEST_S3_ENDPOINT_URL=http://minio:9000
AMBYTE_INGEST_S3_BUCKET_NAME=ambyte-raw

# Target Databricks Workspace
AMBYTE_DATABRICKS_HOST=https://adb-123456789.1.azuredatabricks.net

# Databricks Auth: Choose Personal Access Token (PAT) OR Service Principal (OAuth)
AMBYTE_DATABRICKS_TOKEN=dapi_your_personal_access_token
# AMBYTE_DATABRICKS_CLIENT_ID=your_sp_client_id
# AMBYTE_DATABRICKS_CLIENT_SECRET=your_sp_client_secret

# The SQL Warehouse ID where Governance UDFs (Row Filters/Masks) will be created
# Find this in Databricks -> SQL Warehouses -> (Warehouse) -> Execution Details
AMBYTE_DATABRICKS_WAREHOUSE_ID=your_warehouse_id

# Schema where Ambyte will place compiled SQL functions
AMBYTE_DATABRICKS_GOVERNANCE_CATALOG=main
AMBYTE_DATABRICKS_GOVERNANCE_SCHEMA=ambyte_governance

# Scoping: Restrict which catalogs/schemas are scanned by the crawler
AMBYTE_DATABRICKS_INCLUDE_CATALOGS=main,prod
AMBYTE_DATABRICKS_EXCLUDE_SCHEMAS=information_schema,temp_*

# Ambyte Cloud Sync API Key (Needs `resource:write` scope)
CONNECTOR_API_KEY=sk_live_your_machine_key

# Set to "true" to output to local resources.yaml instead of syncing to the cloud
AMBYTE_DATABRICKS_LOCAL_MODE=false